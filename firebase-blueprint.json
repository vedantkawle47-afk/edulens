{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user role and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student performance and risk data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "score": { "type": "number" },
        "attendance": { "type": "number" },
        "assignments": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["LOW", "MED", "HIGH"] },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "score", "attendance", "riskLevel"]
    },
    "QuestionPaper": {
      "title": "Question Paper",
      "description": "Uploaded exam papers with extracted questions",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "fileUrl": { "type": "string" },
        "questions": { "type": "array", "items": { "type": "string" } },
        "isSet": { "type": "boolean" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "fileUrl", "questions"]
    },
    "AnswerSheet": {
      "title": "Answer Sheet",
      "description": "Student answer sheets with AI grading",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "paperId": { "type": "string" },
        "subject": { "type": "string" },
        "fileUrl": { "type": "string" },
        "aiFeedback": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "percentage": { "type": "number" },
        "checkedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "paperId", "fileUrl"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student performance records"
    },
    "/questionPapers/{paperId}": {
      "schema": "QuestionPaper",
      "description": "Exam papers"
    },
    "/answerSheets/{sheetId}": {
      "schema": "AnswerSheet",
      "description": "Student exam submissions"
    }
  }
}
