<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EduLens — AI-Powered Student Analytics</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --dark:#060f1e;
  --navy:#0a1a2e;
  --blue:#0e3460;
  --teal:#0d7a8a;
  --mint:#02c39a;
  --mint2:#00f5c4;
  --white:#f0f8ff;
  --muted:#7baec4;
  --amber:#f4a261;
  --coral:#e76f51;
  --card:#0d1f36;
}
html{scroll-behavior:smooth}
body{background:var(--dark);color:var(--white);font-family:'DM Sans',sans-serif;font-weight:300;overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.2rem 5%;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(20px);background:rgba(6,15,30,0.85);border-bottom:1px solid rgba(2,195,154,0.1)}
.logo{font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--white);letter-spacing:-0.02em}
.logo span{color:var(--mint)}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:0.9rem;font-weight:400;transition:color 0.2s}
.nav-links a:hover{color:var(--mint)}
.nav-cta{background:var(--mint);color:var(--dark);padding:0.55rem 1.4rem;border-radius:50px;font-size:0.88rem;font-weight:500;text-decoration:none;transition:all 0.2s}
.nav-cta:hover{background:var(--mint2);transform:translateY(-1px)}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;padding:8rem 5% 5rem;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;pointer-events:none}
.hero-orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:0.15}
.orb1{width:700px;height:700px;background:var(--teal);top:-200px;right:-150px}
.orb2{width:400px;height:400px;background:var(--mint);bottom:-100px;left:-100px}
.orb3{width:300px;height:300px;background:var(--blue);top:40%;left:30%}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;width:100%;max-width:1200px;margin:0 auto;position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(2,195,154,0.1);border:1px solid rgba(2,195,154,0.3);padding:0.4rem 1rem;border-radius:50px;font-size:0.78rem;color:var(--mint);font-family:'JetBrains Mono',monospace;margin-bottom:1.5rem;animation:fadeUp 0.6s ease both}
.hero-badge::before{content:'';width:6px;height:6px;background:var(--mint);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
h1{font-family:'DM Serif Display',serif;font-size:clamp(2.8rem,5vw,4.5rem);line-height:1.1;letter-spacing:-0.03em;animation:fadeUp 0.7s ease 0.1s both}
h1 em{color:var(--mint);font-style:normal}
.hero-sub{color:var(--muted);font-size:1.1rem;line-height:1.7;margin:1.5rem 0 2.5rem;max-width:500px;animation:fadeUp 0.7s ease 0.2s both}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;animation:fadeUp 0.7s ease 0.3s both}
.btn-primary{background:var(--mint);color:var(--dark);padding:0.85rem 2rem;border-radius:50px;font-weight:500;text-decoration:none;font-size:0.95rem;transition:all 0.25s;display:inline-flex;align-items:center;gap:0.5rem}
.btn-primary:hover{background:var(--mint2);transform:translateY(-2px);box-shadow:0 10px 30px rgba(2,195,154,0.3)}
.btn-ghost{border:1px solid rgba(255,255,255,0.2);color:var(--white);padding:0.85rem 2rem;border-radius:50px;font-weight:400;text-decoration:none;font-size:0.95rem;transition:all 0.25s}
.btn-ghost:hover{border-color:var(--mint);color:var(--mint)}
.hero-visual{position:relative;animation:fadeUp 0.8s ease 0.4s both}
.dashboard-mock{background:var(--card);border:1px solid rgba(2,195,154,0.15);border-radius:16px;padding:1.5rem;box-shadow:0 40px 80px rgba(0,0,0,0.5)}
.mock-topbar{display:flex;align-items:center;gap:0.5rem;margin-bottom:1.2rem}
.mock-dot{width:8px;height:8px;border-radius:50%}
.mock-title{font-size:0.8rem;color:var(--muted);margin-left:0.5rem;font-family:'JetBrains Mono',monospace}
.mock-stats{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-bottom:1rem}
.mock-stat{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:0.9rem}
.mock-stat-val{font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--mint)}
.mock-stat-label{font-size:0.7rem;color:var(--muted);margin-top:0.2rem}
.mock-bars{display:flex;flex-direction:column;gap:0.6rem}
.mock-bar-row{display:flex;align-items:center;gap:0.8rem}
.mock-bar-name{font-size:0.72rem;color:var(--muted);width:70px;flex-shrink:0}
.mock-bar-track{flex:1;height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden}
.mock-bar-fill{height:100%;border-radius:3px;animation:barGrow 1.5s ease both}
@keyframes barGrow{from{width:0%}}
.mock-bar-pct{font-size:0.7rem;color:var(--white);font-family:'JetBrains Mono',monospace;width:28px;text-align:right}
.alert-badge{position:absolute;top:-12px;right:-12px;background:var(--coral);color:white;font-size:0.72rem;font-weight:500;padding:0.35rem 0.75rem;border-radius:50px;font-family:'JetBrains Mono',monospace;animation:bounce 2s ease infinite}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}

/* STATS STRIP */
.stats-strip{background:var(--navy);border-top:1px solid rgba(2,195,154,0.1);border-bottom:1px solid rgba(2,195,154,0.1);padding:3rem 5%}
.stats-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;text-align:center}
.stat-item{}
.stat-num{font-family:'DM Serif Display',serif;font-size:2.8rem;color:var(--mint);letter-spacing:-0.03em}
.stat-desc{font-size:0.85rem;color:var(--muted);margin-top:0.3rem;line-height:1.5}

/* SECTIONS */
section{padding:6rem 5%}
.section-inner{max-width:1200px;margin:0 auto}
.section-tag{font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:var(--mint);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:1rem}
.section-title{font-family:'DM Serif Display',serif;font-size:clamp(2rem,4vw,3rem);line-height:1.15;letter-spacing:-0.02em;margin-bottom:1rem}
.section-sub{color:var(--muted);font-size:1rem;line-height:1.7;max-width:560px}

/* FEATURES */
.features-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-top:4rem}
.feature-card{background:var(--card);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:2rem;transition:all 0.3s;position:relative;overflow:hidden}
.feature-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(2,195,154,0.05),transparent);opacity:0;transition:opacity 0.3s}
.feature-card:hover{border-color:rgba(2,195,154,0.3);transform:translateY(-4px);box-shadow:0 20px 40px rgba(0,0,0,0.3)}
.feature-card:hover::before{opacity:1}
.feature-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:1.2rem}
.fi-mint{background:rgba(2,195,154,0.12)}
.fi-amber{background:rgba(244,162,97,0.12)}
.fi-teal{background:rgba(13,122,138,0.2)}
.fi-coral{background:rgba(231,111,81,0.12)}
.feature-title{font-family:'DM Serif Display',serif;font-size:1.3rem;margin-bottom:0.7rem}
.feature-desc{color:var(--muted);font-size:0.92rem;line-height:1.7}
.feature-tag{display:inline-block;margin-top:1rem;font-size:0.72rem;font-family:'JetBrains Mono',monospace;color:var(--mint);background:rgba(2,195,154,0.1);padding:0.25rem 0.7rem;border-radius:50px}

/* HOW IT WORKS */
.hiw{background:var(--navy)}
.hiw-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-top:4rem}
.steps{display:flex;flex-direction:column;gap:0}
.step{display:flex;gap:1.5rem;position:relative;padding-bottom:2.5rem}
.step:last-child{padding-bottom:0}
.step-left{display:flex;flex-direction:column;align-items:center}
.step-num{width:44px;height:44px;border-radius:50%;background:var(--mint);color:var(--dark);font-weight:500;font-size:0.9rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'JetBrains Mono',monospace}
.step-line{width:2px;flex:1;background:linear-gradient(to bottom,var(--mint),rgba(2,195,154,0.1));margin-top:8px}
.step:last-child .step-line{display:none}
.step-content{padding-top:0.5rem}
.step-title{font-family:'DM Serif Display',serif;font-size:1.2rem;margin-bottom:0.5rem}
.step-desc{color:var(--muted);font-size:0.9rem;line-height:1.6}
.hiw-visual{position:relative}
.pipeline-box{background:var(--card);border:1px solid rgba(2,195,154,0.15);border-radius:16px;padding:2rem}
.pipe-row{display:flex;align-items:center;gap:0.8rem;padding:0.9rem;border-radius:10px;margin-bottom:0.6rem;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.04);transition:all 0.3s}
.pipe-row:hover{background:rgba(2,195,154,0.05);border-color:rgba(2,195,154,0.2)}
.pipe-icon{width:36px;height:36px;border-radius:8px;background:rgba(2,195,154,0.12);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.pipe-label{font-size:0.85rem;font-weight:400}
.pipe-sub{font-size:0.72rem;color:var(--muted)}
.pipe-arrow{margin-left:auto;color:var(--mint);font-size:1rem}

/* TESTIMONIALS */
.testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:4rem}
.tcard{background:var(--card);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:1.8rem}
.tcard-quote{color:var(--muted);font-size:0.92rem;line-height:1.7;font-style:italic;margin-bottom:1.5rem}
.tcard-quote::before{content:'"';font-family:'DM Serif Display',serif;font-size:2rem;color:var(--mint);line-height:0;vertical-align:-0.4em;margin-right:4px}
.tcard-author{display:flex;align-items:center;gap:0.8rem}
.tcard-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:500;color:var(--dark)}
.tcard-name{font-size:0.85rem;font-weight:500}
.tcard-role{font-size:0.75rem;color:var(--muted)}

/* CTA */
.cta-section{background:linear-gradient(135deg,var(--blue),var(--navy));border-top:1px solid rgba(2,195,154,0.15);text-align:center;padding:7rem 5%}
.cta-inner{max-width:700px;margin:0 auto}
.cta-title{font-family:'DM Serif Display',serif;font-size:clamp(2rem,4vw,3.2rem);line-height:1.15;margin-bottom:1.2rem}
.cta-sub{color:var(--muted);font-size:1rem;line-height:1.7;margin-bottom:2.5rem}
.cta-btns{display:flex;justify-content:center;gap:1rem;flex-wrap:wrap}

/* FOOTER */
footer{background:var(--dark);border-top:1px solid rgba(255,255,255,0.06);padding:3rem 5%}
.footer-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.footer-logo{font-family:'DM Serif Display',serif;font-size:1.3rem}
.footer-logo span{color:var(--mint)}
.footer-links{display:flex;gap:2rem;list-style:none}
.footer-links a{color:var(--muted);font-size:0.85rem;text-decoration:none;transition:color 0.2s}
.footer-links a:hover{color:var(--mint)}
.footer-copy{color:var(--muted);font-size:0.8rem}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* SCROLL REVEAL */
.reveal{opacity:0;transform:translateY(30px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* RESPONSIVE */
@media(max-width:768px){
  .hero-grid,.hiw-grid{grid-template-columns:1fr}
  .hero-visual{display:none}
  .features-grid,.testimonials-grid{grid-template-columns:1fr}
  .stats-inner{grid-template-columns:1fr 1fr}
  .nav-links{display:none}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">Edu<span>Lens</span></div>
  <ul class="nav-links">
    <li><a href="#features">Features</a></li>
    <li><a href="#how">How It Works</a></li>
    <li><a href="#impact">Impact</a></li>
    <li><a href="#about">About</a></li>
  </ul>
  <a href="#cta" class="nav-cta">Request Demo</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-orb orb1"></div>
    <div class="hero-orb orb2"></div>
    <div class="hero-orb orb3"></div>
  </div>
  <div class="hero-grid">
    <div>
      <div class="hero-badge">🤖 &nbsp;AI-Powered Education Intelligence</div>
      <h1>Every student deserves to be <em>seen</em> before they fall behind.</h1>
      <p class="hero-sub">EduLens uses AI to analyse test results, track attendance, identify learning gaps, and equip teachers with the insights they need to intervene early — automatically.</p>
      <div class="hero-btns">
        <a href="#cta" class="btn-primary">Get Started Free →</a>
        <a href="#how" class="btn-ghost">See How It Works</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="dashboard-mock">
        <div class="mock-topbar">
          <div class="mock-dot" style="background:#e74c3c"></div>
          <div class="mock-dot" style="background:#f39c12"></div>
          <div class="mock-dot" style="background:#2ecc71"></div>
          <span class="mock-title">EduLens Dashboard · Live</span>
        </div>
        <div class="mock-stats">
          <div class="mock-stat">
            <div class="mock-stat-val">87</div>
            <div class="mock-stat-label">At-risk students</div>
          </div>
          <div class="mock-stat">
            <div class="mock-stat-val">88%</div>
            <div class="mock-stat-label">Attendance rate</div>
          </div>
          <div class="mock-stat">
            <div class="mock-stat-val">71%</div>
            <div class="mock-stat-label">Avg. performance</div>
          </div>
          <div class="mock-stat">
            <div class="mock-stat-val" style="color:var(--amber)">12</div>
            <div class="mock-stat-label">New AI alerts</div>
          </div>
        </div>
        <div class="mock-bars">
          <div style="font-size:0.72rem;color:var(--muted);margin-bottom:0.4rem;font-family:'JetBrains Mono',monospace">Learning gaps by subject</div>
          <div class="mock-bar-row"><div class="mock-bar-name">Mathematics</div><div class="mock-bar-track"><div class="mock-bar-fill" style="width:78%;background:#e24b4a;animation-delay:0.3s"></div></div><div class="mock-bar-pct">78%</div></div>
          <div class="mock-bar-row"><div class="mock-bar-name">Physics</div><div class="mock-bar-track"><div class="mock-bar-fill" style="width:64%;background:#f4a261;animation-delay:0.5s"></div></div><div class="mock-bar-pct">64%</div></div>
          <div class="mock-bar-row"><div class="mock-bar-name">Chemistry</div><div class="mock-bar-track"><div class="mock-bar-fill" style="width:55%;background:#f4a261;animation-delay:0.7s"></div></div><div class="mock-bar-pct">55%</div></div>
          <div class="mock-bar-row"><div class="mock-bar-name">English</div><div class="mock-bar-track"><div class="mock-bar-fill" style="width:41%;background:#02c39a;animation-delay:0.9s"></div></div><div class="mock-bar-pct">41%</div></div>
        </div>
      </div>
      <div class="alert-badge">⚠ 3 students need attention</div>
    </div>
  </div>
</section>

<!-- STATS -->
<div class="stats-strip reveal">
  <div class="stats-inner">
    <div class="stat-item"><div class="stat-num">40%</div><div class="stat-desc">Earlier detection of at-risk students vs. traditional methods</div></div>
    <div class="stat-item"><div class="stat-num">3×</div><div class="stat-desc">Faster teacher intervention when AI alerts are enabled</div></div>
    <div class="stat-item"><div class="stat-num">25%</div><div class="stat-desc">Improvement in average test scores after targeted support</div></div>
    <div class="stat-item"><div class="stat-num">60%</div><div class="stat-desc">Reduction in chronic absenteeism across tracked cohorts</div></div>
  </div>
</div>

<!-- FEATURES -->
<section id="features">
  <div class="section-inner">
    <div class="reveal">
      <div class="section-tag">Core Capabilities</div>
      <h2 class="section-title">Everything a school needs to<br/>support every student.</h2>
      <p class="section-sub">Four powerful AI modules working together to give teachers and administrators a complete picture of every learner.</p>
    </div>
    <div class="features-grid">
      <div class="feature-card reveal">
        <div class="feature-icon fi-mint">📊</div>
        <div class="feature-title">Learning Gap Detection</div>
        <p class="feature-desc">AI analyses individual test results and answer patterns — not just final scores — to identify the exact topics each student struggles with. Pinpoint Mathematics, Physics, or Language gaps at a concept level.</p>
        <span class="feature-tag">Deep Knowledge Tracing</span>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon fi-amber">📅</div>
        <div class="feature-title">Attendance & Behaviour Tracking</div>
        <p class="feature-desc">Integrates attendance records, assignment submissions, and classroom engagement data to detect early warning patterns — including subject-specific absenteeism that traditional registers miss entirely.</p>
        <span class="feature-tag">Behavioural Pattern Analysis</span>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon fi-teal">👩‍🏫</div>
        <div class="feature-title">Teacher Support & Guidance</div>
        <p class="feature-desc">Delivers prioritised, explainable alerts directly to teachers — showing not just who needs help, but why, and what to do. Evidence-based instructional strategies are surfaced automatically for each student.</p>
        <span class="feature-tag">Explainable AI (XAI)</span>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon fi-coral">❤️</div>
        <div class="feature-title">Student Well-being & Outcomes</div>
        <p class="feature-desc">Monitors holistic signals — academic, behavioural, and social — to flag students who may need pastoral support. Early action prevents small setbacks from becoming serious academic crises.</p>
        <span class="feature-tag">Holistic Student Profiles</span>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="hiw" id="how">
  <div class="section-inner">
    <div class="reveal">
      <div class="section-tag">The Process</div>
      <h2 class="section-title">From raw data to<br/>real intervention.</h2>
      <p class="section-sub">EduLens turns scattered school data into a clear, actionable intelligence pipeline — in four steps.</p>
    </div>
    <div class="hiw-grid">
      <div class="steps reveal">
        <div class="step">
          <div class="step-left">
            <div class="step-num">01</div>
            <div class="step-line"></div>
          </div>
          <div class="step-content">
            <div class="step-title">Data Ingestion</div>
            <p class="step-desc">EduLens connects to your existing Student Information System, LMS, attendance registers, and assessment platforms. No manual data entry required.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-left">
            <div class="step-num">02</div>
            <div class="step-line"></div>
          </div>
          <div class="step-content">
            <div class="step-title">AI Analysis</div>
            <p class="step-desc">Machine learning models process the data in real time — scoring student risk levels, tracing knowledge gaps, and detecting behavioural anomalies across all subjects.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-left">
            <div class="step-num">03</div>
            <div class="step-line"></div>
          </div>
          <div class="step-content">
            <div class="step-title">Insight Delivery</div>
            <p class="step-desc">Prioritised alerts and performance summaries are delivered through role-specific dashboards — administrators see school-wide trends, teachers see individual student alerts.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-left">
            <div class="step-num">04</div>
          </div>
          <div class="step-content">
            <div class="step-title">Intervention & Feedback</div>
            <p class="step-desc">Teachers act on recommendations and record outcomes. Results feed back into the model, making EduLens smarter with every intervention.</p>
          </div>
        </div>
      </div>
      <div class="hiw-visual reveal">
        <div class="pipeline-box">
          <div style="font-size:0.72rem;color:var(--muted);font-family:'JetBrains Mono',monospace;margin-bottom:1rem">AI PIPELINE · REAL-TIME</div>
          <div class="pipe-row"><div class="pipe-icon">🏫</div><div><div class="pipe-label">School Data Sources</div><div class="pipe-sub">SIS · LMS · Attendance</div></div><div class="pipe-arrow">›</div></div>
          <div class="pipe-row"><div class="pipe-icon">🧠</div><div><div class="pipe-label">ML Risk Scoring</div><div class="pipe-sub">Classification · Clustering</div></div><div class="pipe-arrow">›</div></div>
